# Single source of truth for local uv and Docker runtime.
APP_ENV=development

# Repo-relative data directory used by both local Python/uv and Docker.
# In Docker, the app runs from /app, so ./data resolves to /app/data.
APP_DATA_DIR=./data

APP_PORT=8000

# binary = store PDF BLOBs in SQLite
# file   = store .pdf files under APP_DATA_DIR/pdf_storage and paths in SQLite
PDF_STORAGE_MODE=binary

# auto      = normal in both local and Docker runtimes
# normal    = standard SQLite locking
# exclusive = safer for SQLite WAL on Windows Docker bind mounts
SQLITE_LOCKING_MODE=auto
